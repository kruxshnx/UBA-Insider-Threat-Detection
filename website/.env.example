# ── UBA ITD dashboard — frontend environment ──────────────────────────────
# Copy to `.env` (or `.env.local`) and adjust. All Vite client vars must be
# prefixed with VITE_ to be exposed to the browser.

# Base URL of the backend API host (NO trailing slash, NO "/api" suffix —
# the client appends "/api" itself, e.g. requests hit `${VITE_API_URL}/api/...`).
#
#   • Leave BLANK for local dev: requests become "/api/..." and are proxied to
#     http://localhost:8000 by vite.config.js.
#   • In production set the deployed API origin, e.g.
#       VITE_API_URL=https://api.uba-itd.example.com
VITE_API_URL=
