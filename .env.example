# ──────────────────────────────────────────────────────────────────────────────
# UBA & Insider Threat Detection — environment template
# Copy to `.env` (which is gitignored) and fill in real values.
# ──────────────────────────────────────────────────────────────────────────────

# Optional LLM endpoint (only used if you enable the optional LLM-assisted
# explanation features). Leave as-is if unused.
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=qwen/qwen-3-5-397b-instruct
OPENAI_API_KEY=your-key-here

# ── Backend API settings (read by src/api/config.py) ─────────────────────────
# All optional — sensible defaults come from config.yaml.
UBA_LOG_LEVEL=INFO
UBA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# UBA_RATE_LIMIT_REQUESTS=100
# UBA_RATE_LIMIT_WINDOW=60
# UBA_CACHE_TTL=30

# ── Security ─────────────────────────────────────────────────────────────────
# Override the dev-only default PII pseudonymization salt in real deployments.
# UBA_PII_SALT=change-me-in-production

# ── Frontend (build-time, read by Vite) ──────────────────────────────────────
# Leave empty to use a relative "/api" base (works with the nginx reverse proxy
# in docker-compose). Set to an absolute URL only for a split deployment.
# VITE_API_URL=
